# secrets NEVER go in the repo — they live in GitHub Actions Secrets
.env

node_modules/
*.log
*.BACKUP.json

# NOTE: data/ IS committed on purpose.
#   data/*.json         -> track records + signals persist between runs
#   data/transcripts/   -> the transcript cache. Committing it is what keeps
#                          Blotato credits at ~0 (otherwise every cloud run
#                          re-downloads the whole back catalogue).

# BestFightOdds page cache (local, re-fetchable)
data/bfo/
# Wikipedia wikitext cache (local, re-fetchable)
data/wiki/
run-deep-backfill.cmd
deep-backfill.log
discover-channels.js
review-quality.js
grade-rerun.log
Start-Dashboard.cmd
dashboard-server.log
# local safety copies of data/predictions.json — the corpus itself is committed, so these
# are redundant in git and would add ~6MB per snapshot.
data/backups/
data/evidence/
