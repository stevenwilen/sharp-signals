# Copy to `.env` and fill in. Nothing here is needed for Kalshi MARKET READS
# (those are public) — only for authenticated Kalshi calls + the social layer.

# Shared results folder. Point BOTH machines at the same synced cloud folder so that
# whoever runs the bot updates the other person's dashboard. Leave blank to use ./data.
#   DATA_DIR=C:\Users\<you>\OneDrive\SharpSignals-data
#   DATA_DIR=/mnt/c/Users/<you>/OneDrive/SharpSignals-data   (WSL)
DATA_DIR=

# Kalshi (create at kalshi.com -> Settings -> API Keys; start on the demo sandbox)
KALSHI_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=./secrets/kalshi_private_key.pem
# Live host is api.elections.kalshi.com; sandbox is demo-api.kalshi.co
KALSHI_HOST=api.elections.kalshi.com

# Social / research layer (the paid APIs)
TWITTERAPI_KEY=        # twitterapi.io or Apify token for pulling handles' posts
YOUTUBE_API_KEY=       # YouTube Data API v3 (free quota)
ASSEMBLYAI_KEY=        # optional: transcribe podcasts/videos without captions

# LLM extraction (turn posts into structured picks). Pick ONE:
GEMINI_API_KEY=        # FREE tier at aistudio.google.com (recommended) — Flash model
ANTHROPIC_API_KEY=     # OR Claude (paid, pennies/card). Gemini is used first if both set.
# EXTRACT_PROVIDER=gemini   # force a provider; default: gemini if its key exists, else claude
# EXTRACT_MODEL=gemini-3.5-flash-lite   # pinned default (a specific version, never a -latest alias)
